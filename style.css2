
h2 {
    text-align: center;
    font-family: Arial, sans-serif;
}


table {
    margin: 30px auto;
    border-collapse: collapse;
    width: 80%;
    text-align: center;
    font-family: Arial, sans-serif;
}


table, th, td {
    border: 2px solid black;
    padding: 10px;
}


th {
    background-color: #4CAF50;
    color: white;
}


tr:nth-child(even) {
    background-color: #f2f2f2;
}